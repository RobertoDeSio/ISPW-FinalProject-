<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="700.0" prefWidth="1000.0" styleClass="main-container" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>

        <!-- Bottone indietro in alto a sinistra -->
        <HBox style="-fx-padding: 20 0 0 40;">
            <children>
                <Button text="← Torna alla Home"
                        onAction="#handleHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;"/>
            </children>
        </HBox>

        <!-- Card centrata -->
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <VBox maxWidth="460.0" styleClass="card-white"
                      style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 16, 0, 0, 4);">

                    <!-- Header blu -->
                    <VBox style="-fx-background-color: #2563EB; -fx-background-radius: 12 12 0 0; -fx-padding: 24 28 24 28;" spacing="6">
                        <children>
                            <Label text="Crea un Account"
                                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: BOLD;"/>
                            <Label text="Unisciti alla community Weekender"
                                   style="-fx-text-fill: #BFDBFE; -fx-font-size: 13px;"/>
                        </children>
                    </VBox>

                    <!-- Campi -->
                    <VBox spacing="16" style="-fx-padding: 28 28 28 28;">
                        <children>

                            <!-- Tipo account -->
                            <VBox spacing="8">
                                <children>
                                    <Label text="Tipo di Account" styleClass="form-label"/>
                                    <HBox spacing="12">
                                        <children>
                                            <VBox fx:id="cardCliente" alignment="CENTER" spacing="6"
                                                  style="-fx-border-color: #2563EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand; -fx-background-color: white;"
                                                  onMouseClicked="#handleSelezionaCliente"
                                                  HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="👤" style="-fx-font-size: 20px;"/>
                                                    <Label text="Cliente" styleClass="card-title-dark"/>
                                                    <Label text="Prenota attività" styleClass="card-desc-dark"/>
                                                </children>
                                            </VBox>
                                            <VBox fx:id="cardOrganizzatore" alignment="CENTER" spacing="6"
                                                  style="-fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand; -fx-background-color: white;"
                                                  onMouseClicked="#handleSelezionaOrganizzatore"
                                                  HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="👤" style="-fx-font-size: 20px;"/>
                                                    <Label text="Organizzatore" styleClass="card-title-dark"/>
                                                    <Label text="Crea eventi" styleClass="card-desc-dark"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <VBox spacing="6">
                                <children>
                                    <Label text="Email" styleClass="form-label"/>
                                    <TextField fx:id="fieldEmail" promptText="nome@esempio.com" styleClass="form-input"/>
                                </children>
                            </VBox>

                            <VBox spacing="6">
                                <children>
                                    <Label text="Password" styleClass="form-label"/>
                                    <PasswordField fx:id="fieldPassword" promptText="Minimo 6 caratteri" styleClass="form-input"/>
                                </children>
                            </VBox>

                            <VBox spacing="6">
                                <children>
                                    <Label text="Conferma Password" styleClass="form-label"/>
                                    <PasswordField fx:id="fieldConfermaPassword" promptText="Ripeti la password" styleClass="form-input"/>
                                </children>
                            </VBox>

                            <Button text="Registrati"
                                    onAction="#handleRegistrazione"
                                    styleClass="btn-blue"
                                    maxWidth="Infinity"/>

                            <HBox alignment="CENTER" spacing="4">
                                <children>
                                    <Label text="Hai già un account?" styleClass="card-desc-dark"/>
                                    <Button text="Accedi"
                                            onAction="#handleAccedi"
                                            styleClass="link-button"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
